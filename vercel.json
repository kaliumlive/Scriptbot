{
  "functions": {
    "app/api/agents/**": {
      "maxDuration": 60
    },
    "app/api/carousel/**": {
      "maxDuration": 60
    },
    "app/api/video/**": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" }
      ]
    }
  ]
}
